# ── Application ─────────────────────────────────────────────────
APP_NAME=FootGolf Score
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://footgolf:footgolf_secret@localhost:5432/footgolf_db
DATABASE_TEST_URL=postgresql://footgolf:footgolf_secret@localhost:5432/footgolf_test_db

# ── JWT ─────────────────────────────────────────────────────────
SECRET_KEY=CHANGE-THIS-USE-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Rate Limiting ───────────────────────────────────────────────
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_MINUTES=15

# ── Admin initial ───────────────────────────────────────────────
ADMIN_EMAIL=admin@footgolf.com
ADMIN_PASSWORD=CHANGE-THIS-STRONG-PASSWORD
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=FootGolf
